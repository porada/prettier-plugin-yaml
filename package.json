{
	"name": "prettier-plugin-yaml",
	"version": "1.1.2",
	"description": "Additional YAML formatting options for Prettier",
	"license": "MIT",
	"author": {
		"name": "Dom Porada",
		"email": "dom@dom.engineering",
		"url": "https://dom.engineering"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/porada/prettier-plugin-yaml.git"
	},
	"keywords": [
		"formatting",
		"prettier",
		"prettier-plugin",
		"yaml",
		"yml"
	],
	"files": [
		"dist/**"
	],
	"type": "module",
	"sideEffects": false,
	"exports": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"yaml": "^2.8.3"
	},
	"peerDependencies": {
		"prettier": ">=3"
	},
	"devDependencies": {
		"@standard-config/eslint": "^1.6.1",
		"@standard-config/oxlint": "^1.6.0",
		"@standard-config/prettier": "^1.11.1",
		"@standard-config/tsconfig": "^2.0.2",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^10.1.0",
		"husky": "9.1.7",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"prettier": "^3.8.1",
		"publint": "^0.3.18",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"scripts": {
		"build": "tsdown",
		"fix": "pnpm format && pnpm lint",
		"format": "prettier --write --ignore-unknown .",
		"format:check": "prettier --check --ignore-unknown .",
		"lint": "oxlint --fix",
		"lint:check": "oxlint --deny-warnings --type-check",
		"prepack": "pnpm run '/^(format:check|lint:check|test|typecheck)$/' && pnpm build",
		"prepare": "husky",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	}
}
