{
	"name": "prettier-plugin-yaml",
	"version": "1.2.0",
	"description": "Additional YAML formatting options for Prettier",
	"license": "MIT",
	"author": {
		"name": "Dom Porada",
		"email": "dom@dom.engineering",
		"url": "https://dom.engineering"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/porada/prettier-plugin-yaml.git"
	},
	"keywords": [
		"formatting",
		"prettier",
		"prettier-plugin",
		"yaml",
		"yml"
	],
	"files": [
		"dist/**"
	],
	"type": "module",
	"sideEffects": false,
	"exports": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@11.3.0",
	"dependencies": {
		"yaml": "^2.9.0"
	},
	"peerDependencies": {
		"prettier": ">=3"
	},
	"devDependencies": {
		"@standard-config/eslint": "^2.2.0",
		"@standard-config/oxlint": "^1.9.0",
		"@standard-config/prettier": "^1.13.3",
		"@standard-config/tsconfig": "^3.1.0",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"publint": "^0.3.21",
		"typescript": "^6.0.3",
		"vite-plus": "^0.1.24",
		"vitest": "^4.1.7"
	},
	"scripts": {
		"build": "vp pack",
		"fix": "pnpm format && pnpm lint && pnpm format",
		"format": "prettier --ignore-unknown --log-level=warn --write .",
		"format:check": "prettier --check --ignore-unknown .",
		"lint": "vp lint --fix",
		"lint:check": "vp lint --deny-warnings --type-check",
		"prepack": "pnpm run '/^(format:check|lint:check|test|typecheck)$/' && pnpm build",
		"prepare": "vp config",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	}
}
